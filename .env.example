# ─── Required (unless using local LLM) ───
OPENAI_API_KEY=sk-...

# ─── Local LLM (Ollama) ───
# Set LLM_PROVIDER=local to route all LLM calls through Ollama
# Set LLM_PROVIDER=openai (default) to use OpenAI API
LLM_PROVIDER=openai
LOCAL_LLM_MODEL=gemma4:31b
EMBEDDING_PROVIDER=local
LOCAL_EMBED_MODEL=nomic-embed-text:v1.5
OLLAMA_BASE_URL=http://localhost:11434

# ─── Gmail + Google Calendar ───
# Download from Google Cloud Console → APIs & Credentials → OAuth 2.0
GMAIL_CREDENTIALS_PATH=/path/to/credentials.json

# ─── Telegram ───
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=your-bot-token

# ─── Discord ───
# Get from https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token

# ─── Notion ───
# Get from https://www.notion.so/my-integrations
NOTION_API_KEY=your-integration-token
