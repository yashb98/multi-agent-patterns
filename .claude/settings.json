{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/telegram_approve.py",
            "timeout": 3700
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "grep -rn '/home/claude/' \"$CLAUDE_FILE_PATH\" 2>/dev/null && echo '⚠️  HARDCODED PATH DETECTED: Replace /home/claude/ with relative paths or os.path.dirname(__file__)' || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python run_all.py*)",
      "Bash(python -m patterns.*)",
      "Bash(python -m jobpulse*)",
      "Bash(python -m pytest*)",
      "Bash(python -m mindgraph*)",
      "Bash(python -c *)",
      "Bash(pip install*)",
      "Bash(pip freeze*)",
      "Bash(pip list*)",
      "Bash(pip show*)",
      "Bash(wc -l*)",
      "Bash(wc *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(chmod *)",
      "Bash(crontab *)",
      "Bash(npm *)",
      "Bash(node *)",
      "Bash(vercel *)",
      "Bash(./scripts/*)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ps *)",
      "Bash(curl *)",
      "Bash(sleep *)",
      "Bash(nohup *)",
      "Bash(which *)",
      "Bash(date*)",
      "Bash(pwd*)",
      "Bash(echo *)",
      "Bash(/opt/homebrew/anaconda3/bin/python -c *)",
      "Bash(pmset -g)",
      "Bash(pgrep *)"
    ]
  }
}
