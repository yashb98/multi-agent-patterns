{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python scripts/telegram_approve.py",
            "timeout": 3700
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "grep -rn '/home/claude/' \"$CLAUDE_FILE_PATH\" 2>/dev/null && echo '⚠️  HARDCODED PATH DETECTED: Replace /home/claude/ with relative paths or os.path.dirname(__file__)' || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python run_all.py*)",
      "Bash(python -m patterns.*)",
      "Bash(pip install*)",
      "Bash(pip freeze*)",
      "Bash(wc -l*)",
      "Bash(ls*)",
      "Bash(/opt/homebrew/anaconda3/bin/python -c \":*)",
      "Bash(pmset -g)",
      "Bash(gh secret:*)"
    ]
  }
}
